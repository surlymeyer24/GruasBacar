# Copiá este archivo a frontend/.env.local para pruebas con emuladores.
# .env.local no se commitea (está en .gitignore).

VITE_USE_EMULATORS=true

# Si en consola aparece "[vite] failed to connect to websocket" (p. ej. en el
# navegador embebido de Cursor), descomentá la línea siguiente y reiniciá `npm run dev`:
# DISABLE_HMR=true
