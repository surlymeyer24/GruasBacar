# Copiá a functions/.env (no se commitea) para permitir servicios sin fotos en backend.
FOTOS_OPCIONALES_DEV=false

# Misma Web API Key que VITE_FIREBASE_API_KEY del frontend (envío de email de verificación).
FIREBASE_WEB_API_KEY=

# URL a la que vuelve el usuario tras confirmar el email (ej. https://tu-proyecto.web.app/#/login).
APP_CONTINUE_URL=
