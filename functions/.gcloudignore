# Firebase usa este archivo en lugar de .gitignore al empaquetar functions/.
# lib/ y vendor/ deben subirse aunque estén en el .gitignore raíz.

.git
.gitignore
**/.env
**/.env.*
**/ServiceAccountKey.json
**/serviceAccountKey.json

src/
tsconfig.json
scripts/
*.ts
!lib/**/*.js

# node_modules se reinstala en predeploy (npm install --omit=dev)
node_modules/
