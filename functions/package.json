{
  "name": "gruasbacar-functions",
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "npx tsc",
    "predeploy": "node scripts/predeploy.mjs",
