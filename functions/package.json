  },
  "dependencies": {
    "@gruasbacar/shared": "file:./vendor/shared",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "googleapis": "^173.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "private": true
}
